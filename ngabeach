	self.Gui = Create("ScreenGui", { Name = "CrescentHub", ResetOnSpawn = false, Parent = coreGui, ZIndexBehavior = Enum.ZIndexBehavior.Sibling })

	local function GetScale()
		local vp = Camera.ViewportSize
		if vp.X < 600 then return UDim2.fromOffset(vp.X * 0.95, vp.Y * 0.8) end 
		return UDim2.fromOffset(math.clamp(vp.X * 0.55, 500, 800), math.clamp(vp.Y * 0.65, 350, 600))
	end

	self.Main = Create("Frame", {
		Size = GetScale(), Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = Theme.BgVoid, BorderSizePixel = 0, ClipsDescendants = true, Parent = self.Gui
	}, {
		Create("UICorner", {CornerRadius = UDim.new(0, 8)}),
		Create("UIStroke", {Color = Theme.Stroke, Thickness = 1.5}),
	})

	Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function() Tween(self.Main, {Size = GetScale()}, 0.2) end)

	self.Top = Create("Frame", { Size = UDim2.new(1, 0, 0, 50), BackgroundColor3 = Theme.BgMain, Parent = self.Main }, {
		Create("UICorner", {CornerRadius = UDim.new(0, 8)}),
		Create("Frame", {Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1, -1), BackgroundColor3 = Theme.Stroke, BorderSizePixel = 0})
	})

	Create("TextLabel", { Text = titleText, Font = Enum.Font.GothamBold, TextSize = 15, TextColor3 = Theme.Text, TextXAlignment = "Left", BackgroundTransparency = 1, Position = UDim2.fromOffset(20, 10), Size = UDim2.new(0, 200, 0, 20), Parent = self.Top })
	Create("TextLabel", { Text = footerText, Font = Enum.Font.GothamMedium, TextSize = 11, TextColor3 = Theme.Accent, TextXAlignment = "Left", BackgroundTransparency = 1, Size = UDim2.new(0, 200, 0, 15), Position = UDim2.fromOffset(20, 28), Parent = self.Top })

	self.Container = Create("Frame", { Size = UDim2.new(1, 0, 1, -50), Position = UDim2.fromOffset(0, 50), BackgroundTransparency = 1, Parent = self.Main })
	self.Sidebar = Create("Frame", { Size = UDim2.new(0, 150, 1, -20), Position = UDim2.fromOffset(10, 10), BackgroundColor3 = Theme.BgMain, Parent = self.Container }, { Create("UICorner", {CornerRadius = UDim.new(0, 6)}), Create("UIStroke", {Color = Theme.Stroke, Thickness = 1}) })
	
	self.TabHolder = Create("ScrollingFrame", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, ScrollBarThickness = 0, Parent = self.Sidebar }, { Create("UIListLayout", {Padding = UDim.new(0, 4), HorizontalAlignment = "Center"}), Create("UIPadding", {PaddingTop = UDim.new(0, 6), PaddingBottom = UDim.new(0, 6)}) })
	self.Pages = Create("Frame", { Size = UDim2.new(1, -180, 1, -20), Position = UDim2.fromOffset(170, 10), BackgroundTransparency = 1, Parent = self.Container })

	-- Drag Logic
	local drag, startPos, dragStart
	self.Top.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
			drag = true; dragStart = inp.Position; startPos = self.Main.Position
			inp.Changed:Connect(function() if inp.UserInputState == Enum.UserInputState.End then drag = false end end)
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if drag and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
			local delta = inp.Position - dragStart
			self.Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	UserInputService.InputBegan:Connect(function(i, gpe) if not gpe and i.KeyCode == Library.ToggleKey then self.Main.Visible = not self.Main.Visible end end)

