function Library:CreateWatermark(text)
	local coreGui = (gethui and gethui()) or Player:WaitForChild("PlayerGui")
	if coreGui:FindFirstChild("CrescentWatermark") then coreGui.CrescentWatermark:Destroy() end

	local wmGui = Create("ScreenGui", {Name = "CrescentWatermark", Parent = coreGui, ZIndexBehavior = Enum.ZIndexBehavior.Sibling})
	local wmFrame = Create("Frame", {
		Size = UDim2.fromOffset(0, 30), Position = UDim2.new(0.5, 0, 0, 15), AnchorPoint = Vector2.new(0.5, 0),
		BackgroundColor3 = Theme.BgMain, Parent = wmGui
	}, {
		Create("UICorner", {CornerRadius = UDim.new(0, 6)}),
		Create("UIStroke", {Color = Theme.Stroke, Thickness = 1}),
		Create("UIPadding", {PaddingLeft = UDim.new(0, 15), PaddingRight = UDim.new(0, 15)})
	})

	local wmText = Create("TextLabel", { Text = text, Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = Theme.Accent, BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), Parent = wmFrame })
