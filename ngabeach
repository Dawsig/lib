	Accent = Color3.fromRGB(155, 110, 255),
	AccentDark = Color3.fromRGB(110, 70, 200),
	Text = Color3.fromRGB(240, 240, 250),
	SubText = Color3.fromRGB(160, 155, 180),
	Stroke = Color3.fromRGB(40, 35, 60),
	Hover = Color3.fromRGB(30, 25, 45)
}

local function Create(class, props, children)
	local obj = Instance.new(class)
	for k, v in pairs(props or {}) do obj[k] = v end
	for _, c in pairs(children or {}) do c.Parent = obj end
	return obj
end

local function Tween(obj, props, time)
	local t = TweenService:Create(obj, TweenInfo.new(time or 0.2, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), props)
	t:Play()
	return t
end

