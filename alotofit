					Parent = MainButton,
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 15, 0, 26),
					Size = UDim2.new(1, -70, 0, 14),
					Font = Enum.Font.GothamMedium,
					Text = desc,
					TextColor3 = Theme.SubText,
					TextSize = 11,
					TextXAlignment = Enum.TextXAlignment.Left,
					TextTruncate = Enum.TextTruncate.AtEnd
				})
			end
			
			local ValueLabel = Utility:Create("TextLabel", {
				Parent = MainButton,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -110, 0, desc ~= "" and 8 or 0),
				Size = UDim2.new(0, 85, 0, 18),
				Font = Enum.Font.GothamBold,
				Text = selectedText,
				TextColor3 = currentValue ~= nil and Theme.Accent or Theme.SubText,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Right,
				TextTruncate = Enum.TextTruncate.AtEnd
			})
			
			local Arrow = Utility:Create("ImageLabel", {
				Parent = MainButton,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -22, 0.5, -7),
				Size = UDim2.new(0, 14, 0, 14),
				Image = "rbxassetid://6034818371",
				Rotation = 0,
				ImageColor3 = disabled and Theme.SubText or Theme.SubText
			})
			
			local OptionsHolder = Utility:Create("Frame", {
				Parent = DropdownFrame,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 0, 0, desc ~= "" and 58 or 42),
				Size = UDim2.new(1, 0, 0, 0),
				ClipsDescendants = true
			})
			
			local OptionsLayout = Utility:Create("UIListLayout", {
				Parent = OptionsHolder,
				SortOrder = Enum.SortOrder.LayoutOrder,
				Padding = UDim.new(0, 6)
			})
			Utility:Create("UIPadding", {
				Parent = OptionsHolder,
				PaddingLeft = UDim.new(0, 8),
				PaddingRight = UDim.new(0, 8),
				PaddingTop = UDim.new(0, 8),
				PaddingBottom = UDim.new(0, 8)
			})
			
			local function setValue(v)
				currentValue = v
				selectedText = tostring(v)
				ValueLabel.Text = selectedText
				ValueLabel.TextColor3 = Theme.Accent
				callback(v)
			end
			
			local function closeDropdown()
				if not isOpen then return end
				isOpen = false
				local targetHeight = desc ~= "" and 58 or 42
				Utility:Tween(DropdownFrame, TweenInfo.new(0.22, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, targetHeight)})
				Utility:Tween(OptionsHolder, TweenInfo.new(0.22, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, 0)})
				Utility:Tween(Arrow, TweenInfo.new(0.22, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Rotation = 0})
			end
			
			local function openDropdown()
				if isOpen or disabled then return end
				isOpen = true
				local optionHeight = (#selection * 34) + math.max(#selection - 1, 0) * 6 + 16
				local baseHeight = desc ~= "" and 58 or 42
				Utility:Tween(DropdownFrame, TweenInfo.new(0.24, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, baseHeight + optionHeight)})
				Utility:Tween(OptionsHolder, TweenInfo.new(0.24, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, optionHeight)})
				Utility:Tween(Arrow, TweenInfo.new(0.24, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Rotation = 180})
			end
			
			local function toggleDropdown()
				if disabled then return end
				if isOpen then
					closeDropdown()
				else
					openDropdown()
				end
			end
			
			for index, option in ipairs(selection) do
				local optionText = getOptionLabel(option)
				local OptionBtn = Utility:Create("TextButton", {
					Parent = OptionsHolder,
					BackgroundColor3 = Color3.fromRGB(35, 35, 40),
					Size = UDim2.new(1, 0, 0, 34),
					AutoButtonColor = false,
					Text = "",
					LayoutOrder = index
				})
				Utility:Create("UICorner", {CornerRadius = UDim.new(0, 6), Parent = OptionBtn})
				
				Utility:Create("TextLabel", {
					Parent = OptionBtn,
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 12, 0, 0),
					Size = UDim2.new(1, -24, 1, 0),
					Font = Enum.Font.GothamMedium,
					Text = optionText,
					TextColor3 = Theme.Text,
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left,
					TextTruncate = Enum.TextTruncate.AtEnd
				})
				
				OptionBtn.MouseEnter:Connect(function()
					Utility:Tween(OptionBtn, TweenInfo.new(0.15, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {BackgroundColor3 = Color3.fromRGB(40, 40, 46)})
				end)
				OptionBtn.MouseLeave:Connect(function()
					Utility:Tween(OptionBtn, TweenInfo.new(0.15, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {BackgroundColor3 = Color3.fromRGB(35, 35, 40)})
				end)
				OptionBtn.MouseButton1Click:Connect(function()
					if disabled then return end
					setValue(getOptionValue(option))
					closeDropdown()
				end)
			end
			
			MainButton.MouseEnter:Connect(function()
				if not disabled then
					Utility:Tween(DropdownFrame, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(35, 35, 40)})
				end
			end)
			MainButton.MouseLeave:Connect(function()
				Utility:Tween(DropdownFrame, TweenInfo.new(0.15), {BackgroundColor3 = Theme.Element})
			end)
			MainButton.MouseButton1Click:Connect(toggleDropdown)
			
			if currentValue ~= nil then
				setValue(currentValue)
			end
			
			if locked then
				ValueLabel.Text = "Locked"
				ValueLabel.TextColor3 = Theme.SubText
			end
		end

		return TabFunctions
	end
	
	return Window
end

return Cresent