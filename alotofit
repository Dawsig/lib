					BackgroundColor3 = toggled and Theme.Accent or Color3.fromRGB(45, 50, 60)
				})
				Utility:Tween(SwitchDot, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Position = toggled and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
				})
				if fire then
					pcall(callback, toggled)
				end
