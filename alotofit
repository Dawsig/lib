		Parent = main,
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 18, 0, 124),
		Size = UDim2.new(1, -36, 0, 34),
		Font = Enum.Font.GothamMedium,
		Text = tostring(cfg.desc or cfg.Description or "Loading..."),
		TextColor3 = Theme.SubText,
		TextWrapped = true,
		TextSize = 13,
		ZIndex = 3,
	})

	local barBack = new("Frame", {
		Parent = main,
		BackgroundColor3 = Color3.fromRGB(42, 42, 48),
		Position = UDim2.new(0, 18, 1, -26),
		Size = UDim2.new(1, -36, 0, 7),
		ZIndex = 3,
	})
	addCorner(barBack, 99)
	local barFill = new("Frame", {
		Parent = barBack,
		BackgroundColor3 = Theme.Accent,
		Size = UDim2.new(0, 0, 1, 0),
		ZIndex = 4,
	})
	addCorner(barFill, 99)

	main.Position = UDim2.new(0.5, 0, 0.5, 34)
	main.BackgroundTransparency = 1
	overlay.BackgroundTransparency = 1
	tween(overlay, TweenInfo.new(0.2), {BackgroundTransparency = 0.35})
	tween(main, TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, 0, 0.5, 0),
		BackgroundTransparency = 0
	})

	local duration = tonumber(cfg.time or cfg.Time or 2) or 2
	local started = os.clock()
	local connection
	connection = RunService.RenderStepped:Connect(function()
		if not barFill.Parent then
			if connection then connection:Disconnect() end
			return
		end
		local alpha = math.clamp((os.clock() - started) / math.max(duration, 0.1), 0, 1)
		barFill.Size = UDim2.new(alpha, 0, 1, 0)
	end)

	task.delay(duration, function()
		if connection then connection:Disconnect() end
		if overlay.Parent then
			tween(main, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
				Position = UDim2.new(0.5, 0, 0.5, 28),
				BackgroundTransparency = 1
			})
			tween(overlay, TweenInfo.new(0.22), {BackgroundTransparency = 1})
			task.delay(0.25, function()
				if gui.Parent then
					gui:Destroy()
				end
			end)
		end
	end)

	return gui
end

