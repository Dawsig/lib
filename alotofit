		end

		if #Window.Tabs == 1 then
			activate()
		end

		return TabFunctions
	end

	function Window:Destroy()
		closeWindow()
	end

	setWindowVisible(true)

	if useLoader then
		Loader:Start()
	end

	Utility:Tween(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, -360, 0.5, -230)
	})

	return Window
end

return Library
