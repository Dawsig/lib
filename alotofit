		function TabFunctions:Slider(text, min, max, default, callback)
			callback = callback or function() end
			min = tonumber(min) or 0
			max = tonumber(max) or 100
			default = tonumber(default) or min

			local value = math.clamp(default, min, max)

			local SliderFrame = makeControlBackground(Page, 60)

			Utility:Create("TextLabel", {
				Parent = SliderFrame,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 14, 0, 7),
				Size = UDim2.new(1, -86, 0, 16),
				Font = Enum.Font.GothamMedium,
				Text = tostring(text),
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 2
			})

			local ValueLabel = Utility:Create("TextLabel", {
				Parent = SliderFrame,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -72, 0, 7),
				Size = UDim2.new(0, 58, 0, 16),
				Font = Enum.Font.GothamSemibold,
				Text = tostring(value),
				TextColor3 = Theme.Accent,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Right,
				ZIndex = 2
			})

			local BarBg = Utility:Create("Frame", {
				Parent = SliderFrame,
				BackgroundColor3 = Color3.fromRGB(42, 48, 58),
				BorderSizePixel = 0,
				Position = UDim2.new(0, 14, 0, 38),
				Size = UDim2.new(1, -28, 0, 5),
				ZIndex = 2
			})
			makeCorner(BarBg, UDim.new(1, 0))

			local Fill = Utility:Create("Frame", {
				Parent = BarBg,
				BackgroundColor3 = Theme.Accent,
				BorderSizePixel = 0,
				Size = UDim2.new(clamp01((value - min) / (max - min == 0 and 1 or (max - min))), 0, 1, 0),
				ZIndex = 3
			})
			makeCorner(Fill, UDim.new(1, 0))

			local Knob = Utility:Create("Frame", {
				Parent = BarBg,
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				BorderSizePixel = 0,
				AnchorPoint = Vector2.new(0.5, 0.5),
				Position = UDim2.new(clamp01((value - min) / (max - min == 0 and 1 or (max - min))), 0, 0.5, 0),
				Size = UDim2.new(0, 12, 0, 12),
				ZIndex = 4
			})
			makeCorner(Knob, UDim.new(1, 0))

			local Trigger = Utility:Create("TextButton", {
				Parent = BarBg,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 2, 6),
				Position = UDim2.new(0, 0, -0.5, 0),
				Text = "",
				AutoButtonColor = false,
				ZIndex = 5
			})

			local dragging = false

			local function updateFromInput(input)
				local alpha = (input.Position.X - BarBg.AbsolutePosition.X) / BarBg.AbsoluteSize.X
				alpha = clamp01(alpha)

				local newValue = min + ((max - min) * alpha)
				local rounded = math.floor(newValue * 10 + 0.5) / 10
				value = math.clamp(rounded, min, max)

				Fill.Size = UDim2.new(alpha, 0, 1, 0)
				Knob.Position = UDim2.new(alpha, 0, 0.5, 0)
				ValueLabel.Text = tostring(value)
				pcall(callback, value)
			end

			local function setValue(newValue, fire)
				value = math.clamp(tonumber(newValue) or min, min, max)
				local alpha = (value - min) / (max - min == 0 and 1 or (max - min))
				Fill.Size = UDim2.new(alpha, 0, 1, 0)
				Knob.Position = UDim2.new(alpha, 0, 0.5, 0)
				ValueLabel.Text = tostring(math.floor(value * 10 + 0.5) / 10)
				if fire then
					pcall(callback, value)
				end
			end

			setValue(default, false)

			Trigger.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					updateFromInput(input)
				end
			end)

			track(UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					updateFromInput(input)
				end
			end))

			track(UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end))

			return {
				Set = setValue,
				Get = function()
					return value
				end
			}
		end

		function TabFunctions:Dropdown(text, options, callback)
			callback = callback or function() end
			options = typeof(options) == "table" and options or {}

			local selected = options[1] or "Select..."
			local expanded = false

			local DropdownFrame = makeControlBackground(Page, 42)
			DropdownFrame.ClipsDescendants = true

			local DropButton = Utility:Create("TextButton", {
				Parent = DropdownFrame,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 1, 0),
				Text = "",
				AutoButtonColor = false,
				ZIndex = 3
			})

			Utility:Create("TextLabel", {
				Parent = DropdownFrame,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 14, 0, 0),
				Size = UDim2.new(0.48, 0, 1, 0),
				Font = Enum.Font.GothamMedium,
				Text = tostring(text),
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 2
			})

			local SelectedLabel = Utility:Create("TextLabel", {
				Parent = DropdownFrame,
				BackgroundTransparency = 1,
				Position = UDim2.new(0.48, 0, 0, 0),
				Size = UDim2.new(0.46, -26, 1, 0),
				Font = Enum.Font.GothamSemibold,
				Text = tostring(selected),
				TextColor3 = Theme.Accent,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Right,
				ZIndex = 2
			})

			local Chevron = Utility:Create("TextLabel", {
				Parent = DropdownFrame,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -24, 0, 0),
				Size = UDim2.new(0, 14, 1, 0),
				Font = Enum.Font.GothamBold,
				Text = "⌄",
				TextColor3 = Theme.SubText,
				TextSize = 16,
				ZIndex = 2
			})

			local ListHolder = Utility:Create("Frame", {
				Parent = DropdownFrame,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 0, 0, 42),
				Size = UDim2.new(1, 0, 0, 0),
				ClipsDescendants = true,
				ZIndex = 2
			})

			local List = Utility:Create("ScrollingFrame", {
				Parent = ListHolder,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 1, 0),
				CanvasSize = UDim2.new(0, 0, 0, 0),
				ScrollBarThickness = 2,
				ScrollBarImageColor3 = Theme.Accent,
				ScrollBarImageTransparency = 0.35,
				ZIndex = 2
			})

			local ListLayout = Utility:Create("UIListLayout", {
				Parent = List,
				SortOrder = Enum.SortOrder.LayoutOrder,
				Padding = UDim.new(0, 6)
			})

			Utility:Create("UIPadding", {
				Parent = List,
				PaddingTop = UDim.new(0, 8),
				PaddingBottom = UDim.new(0, 8),
				PaddingLeft = UDim.new(0, 10),
				PaddingRight = UDim.new(0, 10)
			})
			bindCanvas(List, ListLayout, 16)

			local function closeDropdown()
				if not expanded then
					return
				end
				expanded = false
				Utility:Tween(DropdownFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Size = UDim2.new(1, 0, 0, 42)
				})
				Utility:Tween(ListHolder, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Size = UDim2.new(1, 0, 0, 0)
				})
				Utility:Tween(Chevron, TweenInfo.new(0.22), {Rotation = 0})
			end

			local function openDropdown()
				expanded = true
				local openHeight = math.min(#options * 32 + 18, 160)
				Utility:Tween(DropdownFrame, TweenInfo.new(0.24, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Size = UDim2.new(1, 0, 0, 42 + openHeight)
				})
				Utility:Tween(ListHolder, TweenInfo.new(0.24, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Size = UDim2.new(1, 0, 0, openHeight)
				})
				Utility:Tween(Chevron, TweenInfo.new(0.22), {Rotation = 180})
			end

			local function refreshOptions()
				for _, child in ipairs(List:GetChildren()) do
					if child:IsA("TextButton") then
						child:Destroy()
					end
				end

				for _, opt in ipairs(options) do
					local Item = Utility:Create("TextButton", {
						Parent = List,
						BackgroundColor3 = Theme.Panel,
						BorderSizePixel = 0,
						Size = UDim2.new(1, 0, 0, 28),
						Font = Enum.Font.GothamMedium,
						Text = tostring(opt),
						TextColor3 = Theme.SubText,
						TextSize = 12,
						AutoButtonColor = false,
						ZIndex = 3
					})
					makeCorner(Item, UDim.new(0, 8))
					makeStroke(Item, 0.9, 1, Theme.Stroke)

					Item.MouseEnter:Connect(function()
						Utility:Tween(Item, TweenInfo.new(0.12), {BackgroundColor3 = Theme.ElementHover, TextColor3 = Theme.Text})
					end)

					Item.MouseLeave:Connect(function()
						Utility:Tween(Item, TweenInfo.new(0.12), {BackgroundColor3 = Theme.Panel, TextColor3 = Theme.SubText})
					end)

					Item.MouseButton1Click:Connect(function()
						selected = opt
						SelectedLabel.Text = tostring(selected)
						closeDropdown()
						pcall(callback, selected)
					end)
				end
			end

			refreshOptions()

			DropButton.MouseEnter:Connect(function()
				Utility:Tween(DropdownFrame, TweenInfo.new(0.15), {BackgroundColor3 = Theme.ElementHover})
			end)

			DropButton.MouseLeave:Connect(function()
				Utility:Tween(DropdownFrame, TweenInfo.new(0.15), {BackgroundColor3 = Theme.Element})
			end)

			DropButton.MouseButton1Click:Connect(function()
				playClickRipple(DropdownFrame, UserInputService:GetMouseLocation())
				if expanded then
					closeDropdown()
				else
					openDropdown()
				end
			end)

			track(UserInputService.InputBegan:Connect(function(input)
				if not expanded then
					return
				end
				if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
					return
				end
				local mouse = UserInputService:GetMouseLocation()
				local absPos = DropdownFrame.AbsolutePosition
				local absSize = DropdownFrame.AbsoluteSize
				local inside = mouse.X >= absPos.X and mouse.X <= absPos.X + absSize.X and mouse.Y >= absPos.Y and mouse.Y <= absPos.Y + absSize.Y
				if not inside then
					closeDropdown()
				end
			end))

			return {
				Set = function(newValue)
					selected = tostring(newValue)
					SelectedLabel.Text = selected
				end,
				Get = function()
					return selected
				end,
				Refresh = refreshOptions
			}
		end

		function TabFunctions:Label(text)
			local Label = Utility:Create("Frame", {
				Parent = Page,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 24)
