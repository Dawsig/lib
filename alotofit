			addStroke(keyButton, Theme.Outline, 1)

			keyButton.MouseButton1Click:Connect(function()
				awaiting = true
				keyButton.Text = "..."
			end)

			UserInputService.InputBegan:Connect(function(input, processed)
				if processed then
					return
				end
				if awaiting then
					if input.UserInputType == Enum.UserInputType.Keyboard then
						bind = input.KeyCode
						keyButton.Text = bind.Name
						awaiting = false
					end
					return
				end
				if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == bind then
					task.spawn(function()
						pcall(callback, bind)
					end)
				end
			end)

			return addItem(wrap), function(v)
				if typeof(v) == "EnumItem" then
					bind = v
					keyButton.Text = bind.Name
				end
			end
		end

		function Tab:Colorpicker(cfg2)
			local cfg = type(cfg2) == "table" and cfg2 or {title = cfg2}
			local titleTxt = tostring(cfg.title or cfg.Title or "Colorpicker")
			local descTxt = tostring(cfg.desc or cfg.Description or "")
			local default = cfg.default or cfg.Default or Color3.fromRGB(120, 160, 255)
			local callback = cfg.callback or cfg.Callback or function() end
			local color = default

			local wrap = new("Frame", {
				Parent = page,
				BackgroundColor3 = Theme.Element,
				Size = UDim2.new(1, 0, 0, descTxt ~= "" and 58 or 44),
				LayoutOrder = #tab.Elements + 1,
			})
			addCorner(wrap, 8)
			addStroke(wrap, Theme.Outline, 1)

			new("TextLabel", {
				Parent = wrap,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 14, 0, 7),
				Size = UDim2.new(1, -90, 0, 16),
				Font = Enum.Font.GothamBold,
				Text = titleTxt,
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
			})
			if descTxt ~= "" then
				new("TextLabel", {
					Parent = wrap,
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 14, 0, 24),
					Size = UDim2.new(1, -90, 0, 14),
					Font = Enum.Font.GothamMedium,
					Text = descTxt,
					TextColor3 = Theme.SubText,
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left,
				})
			end

			local swatch = new("TextButton", {
				Parent = wrap,
				BackgroundColor3 = color,
				Position = UDim2.new(1, -54, 0.5, -12),
				Size = UDim2.new(0, 40, 0, 24),
				Text = "",
				AutoButtonColor = false,
			})
			addCorner(swatch, 6)
			addStroke(swatch, Theme.Outline, 1)

			local palette = nil
			swatch.MouseButton1Click:Connect(function()
				if palette and palette.Parent then
					palette:Destroy()
					palette = nil
					return
				end
				palette = new("Frame", {
					Parent = wrap,
					BackgroundColor3 = Theme.Background,
					Position = UDim2.new(1, -180, 1, 6),
					Size = UDim2.new(0, 176, 0, 128),
					ZIndex = 20,
				})
				addCorner(palette, 8)
				addStroke(palette, Theme.Outline, 1)

				local sat = new("ImageLabel", {
					Parent = palette,
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 8, 0, 8),
					Size = UDim2.new(1, -16, 1, -44),
					Image = "rbxassetid://4155801252",
					ImageColor3 = color,
					ZIndex = 21,
				})
				addCorner(sat, 6)

				local save = new("TextButton", {
					Parent = palette,
					BackgroundColor3 = Theme.Accent,
					Position = UDim2.new(0, 8, 1, -30),
					Size = UDim2.new(1, -16, 0, 22),
					Font = Enum.Font.GothamBold,
					Text = "Select",
					TextColor3 = Theme.Text,
					TextSize = 12,
					AutoButtonColor = false,
					ZIndex = 21,
				})
				addCorner(save, 6)
				save.MouseButton1Click:Connect(function()
					pcall(callback, color)
					palette:Destroy()
					palette = nil
				end)
			end)

			return addItem(wrap), function(v)
				color = v
				swatch.BackgroundColor3 = color
			end
		end

		-- default alias names for familiarity
		Tab.Label = Tab.Label
		Tab.Description = Tab.Paragraph

		button.MouseButton1Click:Connect(function()
			activate(tab)
		end)

		table.insert(tabs, tab)
		if #tabs == 1 then
			task.defer(function()
				activate(tab)
			end)
		end

		return setmetatable(Tab, {__index = Tab})
	end

	Window.Tab = Window.CreateTab
	Window.CreateTab = Window.CreateTab
	Window.Notify = function(_, cfg)
		return self:Notify(cfg)
	end

	return Window
end

function Cresent:CreateWindow(cfg)
	return self:_buildWindow(cfg)
end

function Cresent:Create(config)
	config = config or {}
	return self:_buildWindow({
		title = config.title or config.Title or "Cresent",
		desc = config.desc or config.Description or "Premium UI",
		lock = config.lock or config.Lock or false,
	})
end

return setmetatable(Cresent, {
	__call = function(_, ...)
		return Cresent
	end,
})
