				Parent = track,
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				AnchorPoint = Vector2.new(0.5, 0.5),
				Position = UDim2.new(0, 0, 0.5, 0),
				Size = UDim2.new(0, 14, 0, 14),
			})
			addCorner(knob, 99)
			addStroke(knob, Theme.Accent, 1)

			local clicker = new("TextButton", {
				Parent = track,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 1, 16),
				Position = UDim2.new(0, 0, 0, -5),
				Text = "",
				AutoButtonColor = false,
			})

			local current = math.clamp(default, min, max)
			local dragging = false

			local function apply(value, silent)
				current = math.clamp(value, min, max)
				local alpha = (current - min) / math.max(max - min, 1)
				alpha = math.clamp(alpha, 0, 1)
				valueLabel.Text = tostring(math.floor(current * 100) / 100)
				tween(fill, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
					Size = UDim2.new(alpha, 0, 1, 0)
				})
				tween(knob, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
					Position = UDim2.new(alpha, 0, 0.5, 0)
				})
				if not silent then
					task.spawn(function()
						pcall(callback, current)
					end)
				end
			end

			local function updateFromInput(input)
				local alpha = (input.Position.X - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1)
				alpha = math.clamp(alpha, 0, 1)
				local value = min + (max - min) * alpha
				apply(value)
			end

			clicker.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					updateFromInput(input)
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					updateFromInput(input)
				end
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)

			apply(current, true)
			return addItem(wrap), function(v) apply(v, true) end
		end

