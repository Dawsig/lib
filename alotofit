function Utility:Create(className, properties)
	local obj = Instance.new(className)
	for prop, value in pairs(properties or {}) do
		obj[prop] = value
	end
	return obj
end

function Utility:Tween(instance, info, properties)
	local tween = TweenService:Create(instance, info, properties)
	tween:Play()
	return tween
end

function Utility:SafeCall(callback, ...)
	if type(callback) ~= "function" then
		return
	end
	local ok, err = pcall(callback, ...)
	if not ok then
		warn("[Cresent] Callback error:", err)
	end
end

function Utility:MakeDraggable(topbar, object)
	local dragging, dragInput, dragStart, startPos

	topbar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = object.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	topbar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			Utility:Tween(object, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
				Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
			})
		end
	end)
end

function Utility:BindCanvas(listLayout, scrollingFrame)
	local function update()
		scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 12)
	end
	update()
	listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(update)
end

local function safeHttpGet(url)
	local ok, result = pcall(function()
		return game:HttpGet(url)
	end)
	if ok then
		return result
	end
	ok, result = pcall(function()
		return HttpService:GetAsync(url)
	end)
	if ok then
		return result
	end
	return nil
end

local function loadIconPack(url)
	local source = safeHttpGet(url)
	if not source or source == "" then
		return {}
	end
	local ok, result = pcall(loadstring, source)
	if not ok or type(result) ~= "function" then
		return {}
	end
	local ok2, pack = pcall(result)
	if ok2 and type(pack) == "table" then
		return pack
	end
	return {}
end

