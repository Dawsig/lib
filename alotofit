local Utility = {}
local Connections = {}

local function track(connection)
	table.insert(Connections, connection)
	return connection
end

local function safeSet(instance, property, value)
	pcall(function()
		instance[property] = value
	end)
end

function Utility:Create(className, properties)
	local instance = Instance.new(className)
	if properties then
		for property, value in pairs(properties) do
			safeSet(instance, property, value)
		end
	end
	return instance
end

function Utility:Tween(instance, tweenInfo, properties)
	local ok, tween = pcall(function()
		return TweenService:Create(instance, tweenInfo, properties)
	end)
	if not ok or not tween then
		return nil
	end
	tween:Play()
	return tween
end

local function getParent()
	local parent

	if typeof(gethui) == "function" then
		local ok, hui = pcall(gethui)
		if ok and hui then
			parent = hui
		end
	end

	if not parent then
		local ok, gui = pcall(function()
			return CoreGui
		end)
		if ok and gui then
			parent = gui
		end
	end

	if not parent and LocalPlayer then
		parent = LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui")
	end

	return parent
end

local function bindCanvas(scrollFrame, layout, extraPadding)
	local padding = extraPadding or 0
	local function update()
		if layout and layout.Parent then
			scrollFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + padding)
		end
	end
	update()
	track(layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(update))
	track(scrollFrame.ChildAdded:Connect(update))
	track(scrollFrame.ChildRemoved:Connect(update))
end

