		function TabFunctions:Dropdown(text, options, default, callback)
			options = type(options) == "table" and options or {}
			callback = callback or function() end

			local selected = default
			if selected == nil then
				selected = options[1]
			end
			if selected == nil then
				selected = "Select"
			end

			local open = false
			local dropdownHeight = math.min(36 + (#options * 28), 170)

			local Holder = Utility:Create("Frame", {
				Parent = TabPage,
				BackgroundColor3 = Theme.Element,
				Size = UDim2.new(1, 0, 0, 42),
				ClipsDescendants = true
			})

			Utility:Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = Holder })
			Utility:Create("UIStroke", { Parent = Holder, Color = Theme.Outline, Thickness = 1 })

			local Header = Utility:Create("TextButton", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 42),
				Text = "",
				AutoButtonColor = false
			})

			Utility:Create("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 15, 0, 0),
				Size = UDim2.new(1, -50, 0, 42),
				Font = Enum.Font.GothamMedium,
				Text = text or "Dropdown",
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left
			})

			local SelectedLabel = Utility:Create("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 15, 0, 20),
				Size = UDim2.new(1, -50, 0, 18),
				Font = Enum.Font.Gotham,
				Text = tostring(selected),
				TextColor3 = Theme.SubText,
				TextSize = 11,
				TextXAlignment = Enum.TextXAlignment.Left
			})

			local Arrow = Utility:Create("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, -15, 0, 21),
				Size = UDim2.new(0, 16, 0, 16),
				Font = Enum.Font.GothamBold,
				Text = "⌄",
				TextColor3 = Theme.SubText,
				TextSize = 16
			})

			local OptionFrame = Utility:Create("Frame", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 0, 0, 42),
				Size = UDim2.new(1, 0, 0, 0),
				ClipsDescendants = true
			})

			local OptionList = Utility:Create("UIListLayout", {
				Parent = OptionFrame,
				SortOrder = Enum.SortOrder.LayoutOrder,
				Padding = UDim.new(0, 4)
			})

			Utility:Create("UIPadding", {
				Parent = OptionFrame,
				PaddingTop = UDim.new(0, 4),
				PaddingLeft = UDim.new(0, 4),
				PaddingRight = UDim.new(0, 4),
				PaddingBottom = UDim.new(0, 4),
			})

			local function setSelected(value)
				selected = value
				SelectedLabel.Text = tostring(value)
				Utility:SafeCall(callback, value)
			end

			local function setOpen(state)
				open = state and true or false
				Utility:Tween(Arrow, TweenInfo.new(0.2), { Rotation = open and 180 or 0 })
				Utility:Tween(Holder, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Size = UDim2.new(1, 0, 0, open and (42 + dropdownHeight) or 42)
				})
				Utility:Tween(OptionFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Size = UDim2.new(1, 0, 0, open and dropdownHeight or 0)
				})
			end

			for _, option in ipairs(options) do
				local Item = Utility:Create("TextButton", {
					Parent = OptionFrame,
					BackgroundColor3 = Color3.fromRGB(24, 24, 28),
					Size = UDim2.new(1, 0, 0, 24),
					Text = "",
					AutoButtonColor = false
				})

				Utility:Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Item })

				Utility:Create("TextLabel", {
					Parent = Item,
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 10, 0, 0),
					Size = UDim2.new(1, -20, 1, 0),
					Font = Enum.Font.Gotham,
					Text = tostring(option),
					TextColor3 = Theme.Text,
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left
				})

				Item.MouseEnter:Connect(function()
					Utility:Tween(Item, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(30, 30, 34) })
				end)
				Item.MouseLeave:Connect(function()
					Utility:Tween(Item, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(24, 24, 28) })
				end)
				Item.MouseButton1Click:Connect(function()
					setSelected(option)
					setOpen(false)
				end)
			end

			Header.MouseButton1Click:Connect(function()
				setOpen(not open)
			end)

			setSelected(selected)
		end

