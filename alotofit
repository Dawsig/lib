		function TabFunctions:Slider(text, min, max, default, callback)
			min = tonumber(min) or 0
			max = tonumber(max) or 100
			if max <= min then
				max = min + 1
			end
			local value = tonumber(default) or min
			value = math.clamp(value, min, max)
			callback = callback or function() end

			local SliderFrame = Utility:Create("Frame", {
				Parent = TabPage,
				BackgroundColor3 = Theme.Element,
				Size = UDim2.new(1, 0, 0, 55)
			})

			Utility:Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = SliderFrame })
			Utility:Create("UIStroke", { Parent = SliderFrame, Color = Theme.Outline, Thickness = 1 })

			Utility:Create("TextLabel", {
				Parent = SliderFrame,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 15, 0, 8),
				Size = UDim2.new(0, 150, 0, 20),
				Font = Enum.Font.GothamMedium,
				Text = text or "Slider",
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left
			})

			local ValueLabel = Utility:Create("TextLabel", {
				Parent = SliderFrame,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -65, 0, 8),
				Size = UDim2.new(0, 50, 0, 20),
				Font = Enum.Font.GothamBold,
				Text = tostring(value),
				TextColor3 = Theme.Accent,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Right
			})

			local SlideBg = Utility:Create("Frame", {
				Parent = SliderFrame,
				BackgroundColor3 = Color3.fromRGB(45, 45, 50),
				Position = UDim2.new(0, 15, 0, 38),
				Size = UDim2.new(1, -30, 0, 6)
			})
			Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = SlideBg })

			local SlideFill = Utility:Create("Frame", {
				Parent = SlideBg,
				BackgroundColor3 = Theme.Accent,
				Size = UDim2.new(math.clamp((value - min) / (max - min), 0, 1), 0, 1, 0)
			})
			Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = SlideFill })

			local Trigger = Utility:Create("TextButton", {
				Parent = SlideBg,
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 0, 0, -10),
				Size = UDim2.new(1, 0, 1, 20),
				Text = ""
			})

			local dragging = false
			local function update(input)
				local pos = math.clamp((input.Position.X - SlideBg.AbsolutePosition.X) / math.max(SlideBg.AbsoluteSize.X, 1), 0, 1)
				local newValue = min + (pos * (max - min))
				newValue = math.floor(newValue * 10 + 0.5) / 10
				Utility:Tween(SlideFill, TweenInfo.new(0.08, Enum.EasingStyle.Sine), { Size = UDim2.new(pos, 0, 1, 0) })
				ValueLabel.Text = tostring(newValue)
				Utility:SafeCall(callback, newValue)
			end

			Trigger.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					update(input)
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					update(input)
				end
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)
		end

