			Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = SlideBg })
			
			local SlideFill = Utility:Create("Frame", {
				Parent = SlideBg, BackgroundColor3 = Theme.Accent,
				Size = UDim2.new(math.clamp((value - min) / (max - min), 0, 1), 0, 1, 0)
			})
			Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = SlideFill })
			
			local Knob = Utility:Create("Frame", {
				Parent = SlideFill, BackgroundColor3 = Color3.fromRGB(255,255,255),
				AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(1, 0, 0.5, 0), Size = UDim2.new(0, 14, 0, 14)
			})
			Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Knob })
			Utility:Create("UIStroke", { Parent = Knob, Color = Theme.Outline, Thickness = 1 })
			
			local Trigger = Utility:Create("TextButton", {
				Parent = SlideBg, BackgroundTransparency = 1,
				Position = UDim2.new(0, 0, 0, -10), Size = UDim2.new(1, 0, 1, 20), Text = ""
			})
			
			local dragging = false
			local function update(input)
				local pos = math.clamp((input.Position.X - SlideBg.AbsolutePosition.X) / math.max(SlideBg.AbsoluteSize.X, 1), 0, 1)
				local newValue = math.floor((min + (pos * (max - min))) * 10 + 0.5) / 10
				Utility:Tween(SlideFill, TweenInfo.new(0.08, Enum.EasingStyle.Sine), { Size = UDim2.new(pos, 0, 1, 0) })
				ValueLabel.Text = tostring(newValue)
				Utility:SafeCall(callback, newValue)
			end
			
			Trigger.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					Utility:Tween(Knob, TweenInfo.new(0.2), { Size = UDim2.new(0, 18, 0, 18) })
					update(input)
				end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					update(input)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
					Utility:Tween(Knob, TweenInfo.new(0.2), { Size = UDim2.new(0, 14, 0, 14) })
				end
			end)
		end

		function TabFunctions:Input(text, placeholder, default, callback)
			local Holder = Utility:Create("Frame", {
				Parent = TabPage, BackgroundColor3 = Theme.Element, Size = UDim2.new(1, 0, 0, 54), ClipsDescendants = true
			})
			Utility:Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = Holder })
			Utility:Create("UIStroke", { Parent = Holder, Color = Theme.Outline, Thickness = 1 })
			
			Utility:Create("TextLabel", {
				Parent = Holder, BackgroundTransparency = 1,
				Position = UDim2.new(0, 15, 0, 6), Size = UDim2.new(1, -30, 0, 16),
				Font = Enum.Font.GothamMedium, Text = text, TextColor3 = Theme.Text,
				TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd
			})
			
			local Box = Utility:Create("TextBox", {
				Parent = Holder, BackgroundColor3 = Color3.fromRGB(24, 24, 28), BorderSizePixel = 0,
				Position = UDim2.new(0, 15, 0, 26), Size = UDim2.new(1, -30, 0, 20),
				Font = Enum.Font.Gotham, Text = tostring(default or ""), TextColor3 = Theme.Text,
				TextSize = 12, PlaceholderText = placeholder, PlaceholderColor3 = Theme.SubText,
				ClearTextOnFocus = false, TextXAlignment = Enum.TextXAlignment.Left, ClipsDescendants = true
			})
			Utility:Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Box })
			Utility:Create("UIPadding", { Parent = Box, PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8) })
			
			Box.Focused:Connect(function()
				Utility:Tween(Holder, TweenInfo.new(0.3, Enum.EasingStyle.Quint), { Size = UDim2.new(1, 0, 0, 64), BackgroundColor3 = Color3.fromRGB(35, 35, 40) })
				Utility:Tween(Box, TweenInfo.new(0.3, Enum.EasingStyle.Quint), { Size = UDim2.new(1, -30, 0, 30) })
			end)
			
			Box.FocusLost:Connect(function(enterPressed)
				Utility:Tween(Holder, TweenInfo.new(0.3, Enum.EasingStyle.Quint), { Size = UDim2.new(1, 0, 0, 54), BackgroundColor3 = Theme.Element })
				Utility:Tween(Box, TweenInfo.new(0.3, Enum.EasingStyle.Quint), { Size = UDim2.new(1, -30, 0, 20) })
				if enterPressed then Utility:SafeCall(callback, Box.Text) end
			end)
		end

		function TabFunctions:Dropdown(text, options, default, callback)
			local selected = default or options[1] or "Select"
			local open = false
			local dropdownHeight = math.min(36 + (#options * 28), 170)
			
			local Holder = Utility:Create("Frame", {
				Parent = TabPage, BackgroundColor3 = Theme.Element,
				Size = UDim2.new(1, 0, 0, 42), ClipsDescendants = true
			})
			Utility:Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = Holder })
			Utility:Create("UIStroke", { Parent = Holder, Color = Theme.Outline, Thickness = 1 })
			
			local Header = Utility:Create("TextButton", {
				Parent = Holder, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 42), Text = "", AutoButtonColor = false
			})
			
			Utility:Create("TextLabel", {
				Parent = Holder, BackgroundTransparency = 1,
				Position = UDim2.new(0, 15, 0, 0), Size = UDim2.new(1, -50, 0, 42),
				Font = Enum.Font.GothamMedium, Text = text, TextColor3 = Theme.Text,
				TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd
			})
			
			local SelectedLabel = Utility:Create("TextLabel", {
				Parent = Holder, BackgroundTransparency = 1,
				Position = UDim2.new(0, 15, 0, 20), Size = UDim2.new(1, -50, 0, 18),
				Font = Enum.Font.Gotham, Text = tostring(selected), TextColor3 = Theme.SubText,
				TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd
			})
			
			local Arrow = Utility:Create("TextLabel", {
				Parent = Holder, BackgroundTransparency = 1,
				AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -15, 0, 21),
				Size = UDim2.new(0, 16, 0, 16), Font = Enum.Font.GothamBold, Text = ">",
				TextColor3 = Theme.SubText, TextSize = 16
			})
			
			local OptionFrame = Utility:Create("ScrollingFrame", {
				Parent = Holder, BackgroundTransparency = 1,
				Position = UDim2.new(0, 0, 0, 42), Size = UDim2.new(1, 0, 0, 0),
				ScrollBarThickness = 2, CanvasSize = UDim2.new(0, 0, 0, 0), BorderSizePixel = 0
			})
			local OptionList = Utility:Create("UIListLayout", {
				Parent = OptionFrame, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4)
			})
			Utility:Create("UIPadding", { Parent = OptionFrame, PaddingTop = UDim.new(0, 4), PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4) })
			Utility:BindCanvas(OptionList, OptionFrame)

			local function setOpen(state)
				open = state
				Utility:Tween(Arrow, TweenInfo.new(0.3, Enum.EasingStyle.Quint), { Rotation = open and 90 or 0 })
				Utility:Tween(Holder, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Size = UDim2.new(1, 0, 0, open and (42 + dropdownHeight) or 42)
				})
				Utility:Tween(OptionFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
					Size = UDim2.new(1, 0, 1, -42)
				})
			end

			for _, option in ipairs(options) do
				local Item = Utility:Create("TextButton", {
					Parent = OptionFrame, BackgroundColor3 = Color3.fromRGB(24, 24, 28),
					Size = UDim2.new(1, 0, 0, 24), Text = "", AutoButtonColor = false
				})
				Utility:Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Item })
				Utility:Create("TextLabel", {
					Parent = Item, BackgroundTransparency = 1,
					Position = UDim2.new(0, 10, 0, 0), Size = UDim2.new(1, -20, 1, 0),
					Font = Enum.Font.Gotham, Text = tostring(option), TextColor3 = Theme.Text,
					TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd
				})
				Item.MouseEnter:Connect(function() Utility:Tween(Item, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(30, 30, 34) }) end)
				Item.MouseLeave:Connect(function() Utility:Tween(Item, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(24, 24, 28) }) end)
				Item.MouseButton1Click:Connect(function()
					selected = option
					SelectedLabel.Text = tostring(option)
					Utility:SafeCall(callback, option)
					setOpen(false)
				end)
			end
			Header.MouseButton1Click:Connect(function() setOpen(not open) end)
		end

		function TabFunctions:Paragraph(text)
			local Box = Utility:Create("Frame", {
				Parent = TabPage, BackgroundColor3 = Theme.Element, Size = UDim2.new(1, 0, 0, 70)
			})
			Utility:Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = Box })
			Utility:Create("UIStroke", { Parent = Box, Color = Theme.Outline, Thickness = 1 })
			
			Utility:Create("TextLabel", {
				Parent = Box, BackgroundTransparency = 1,
				Position = UDim2.new(0, 15, 0, 8), Size = UDim2.new(1, -30, 1, -16),
				Font = Enum.Font.Gotham, Text = text, TextColor3 = Theme.SubText,
				TextSize = 12, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top
			})
		end

		return TabFunctions
	end
	return Window
end

return Cresent


