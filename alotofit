function Utility:MakeDraggable(handle, frame)
	handle.Active = true

	local dragging = false
	local dragInput
	local dragStart
	local startPos

	local function update(input)
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end

	track(handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			dragInput = input
		end
	end))

	track(handle.InputEnded:Connect(function(input)
		if input == dragInput then
			dragging = false
			dragInput = nil
		end
	end))

	track(UserInputService.InputChanged:Connect(function(input)
		if dragging and input == dragInput then
			update(input)
		end
	end))
end

local function createRipple(parent)
	local ripple = Utility:Create("Frame", {
		Parent = parent,
		BackgroundColor3 = Theme.Accent,
		BackgroundTransparency = 0.85,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(0, 0),
		ZIndex = parent.ZIndex + 5
	})
	makeCorner(ripple, UDim.new(1, 0))
	return ripple
end

local function playClickRipple(parent, pos)
	local ripple = createRipple(parent)
	local abs = parent.AbsoluteSize
	local maxSize = math.max(abs.X, abs.Y) * 1.4
	ripple.Position = UDim2.new(0, pos.X - parent.AbsolutePosition.X, 0, pos.Y - parent.AbsolutePosition.Y)
	ripple.AnchorPoint = Vector2.new(0.5, 0.5)

	local sizeTween = Utility:Tween(ripple, TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, maxSize, 0, maxSize),
		BackgroundTransparency = 1
	})

	if sizeTween then
		sizeTween.Completed:Connect(function()
			if ripple then
				ripple:Destroy()
			end
		end)
	else
		ripple:Destroy()
	end
end

