		NDesc.TextColor3 = Theme.SubText
		NDesc.Font = Enum.Font.Gotham
		NDesc.TextSize = 13
		NDesc.TextWrapped = true
		NDesc.AutomaticSize = Enum.AutomaticSize.Y
		NDesc.TextXAlignment = Enum.TextXAlignment.Left
		NDesc.TextTransparency = 1
		NDesc.Parent = NotifFrame

		local Pad = Instance.new("UIPadding")
		Pad.PaddingTop = UDim.new(0, 6)
		Pad.PaddingBottom = UDim.new(0, 8)
		Pad.PaddingRight = UDim.new(0, 10)
		Pad.Parent = NotifFrame

		CreateTween(NotifFrame, { BackgroundTransparency = 0.06 }, 0.18)
		CreateTween(NTitle, { TextTransparency = 0 }, 0.18)
		CreateTween(NDesc, { TextTransparency = 0 }, 0.18)
		CreateTween(LeftBar, { BackgroundTransparency = 0 }, 0.18)

		task.delay(duration, function()
			if not NotifFrame or not NotifFrame.Parent then
				return
			end

			CreateTween(NotifFrame, { BackgroundTransparency = 1 }, 0.18)
			CreateTween(NTitle, { TextTransparency = 1 }, 0.18)
			CreateTween(NDesc, { TextTransparency = 1 }, 0.18)
			CreateTween(LeftBar, { BackgroundTransparency = 1 }, 0.18)

			task.delay(0.2, function()
				if NotifFrame and NotifFrame.Parent then
					NotifFrame:Destroy()
				end
			end)
		end)
	end

	function WindowArea:SetAccentColor(color)
		if typeof(color) ~= "Color3" then
			return
		end
		Accent = color
	end

	function WindowArea:Destroy()
		if ScreenGui then
			ScreenGui:Destroy()
		end
	end

	if StartVisible then
		MainShadow.Visible = true
		MainFrame.Visible = true
	else
		MainShadow.Visible = false
		MainFrame.Visible = false
	end

	return WindowArea
end

return Library