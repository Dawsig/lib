	function WindowArea:Notify(opts)
		opts = opts or {}
		local title = opts.Title or "Notification"
		local content = opts.Content or "Description here"
		local duration = opts.Duration or 3

		local NotifFrame = Instance.new("Frame")
		NotifFrame.Size = UDim2.new(1, 0, 0, 0)
		NotifFrame.AutomaticSize = Enum.AutomaticSize.Y
		NotifFrame.BackgroundColor3 = Theme.Panel2
		NotifFrame.BackgroundTransparency = 1
		NotifFrame.Parent = NotifyContainer
		AddCorner(NotifFrame, UDim.new(0, 10))
		AddStroke(NotifFrame, Accent, 0.68, 1)

		local LeftBar = Instance.new("Frame")
		LeftBar.Size = UDim2.new(0, 4, 1, -12)
		LeftBar.Position = UDim2.new(0, 8, 0, 6)
		LeftBar.BackgroundColor3 = Accent
