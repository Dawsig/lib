				if not isMulti then return end
				if #selected == 0 then DropBtn.Text = "  " .. opts.Name
				elseif #selected == 1 then DropBtn.Text = "  " .. opts.Name .. " : " .. selected[1]
				else DropBtn.Text = "  " .. opts.Name .. " : " .. #selected .. " Selected" end
			end

			for _, opt in ipairs(options) do
				local OptBtn = Instance.new("TextButton")
				OptBtn.Size = UDim2.new(1, 0, 0, 35)
				OptBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
				OptBtn.Text = "    " .. opt
				OptBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
				OptBtn.Font = Enum.Font.Gotham
				OptBtn.TextSize = 13
				OptBtn.TextXAlignment = Enum.TextXAlignment.Left
				OptBtn.AutoButtonColor = false
				OptBtn.Selectable = false
				OptBtn.Parent = DropContent
				
				local isSelected = false
				AddHover(OptBtn, Color3.fromRGB(30, 30, 30), Color3.fromRGB(40, 40, 40))

				OptBtn.Activated:Connect(function()
					if isMulti then
						isSelected = not isSelected
						if isSelected then
							table.insert(selected, opt)
							CreateTween(OptBtn, {TextColor3 = PrimaryColor})
						else
							for i, v in ipairs(selected) do if v == opt then table.remove(selected, i) break end end
							CreateTween(OptBtn, {TextColor3 = Color3.fromRGB(180, 180, 180)})
						end
						updateTitle()
						if opts.Callback then opts.Callback(selected) end
					else
						isOpen = false
						DropBtn.Text = "  " .. opts.Name .. " : " .. opt
						CreateTween(Arrow, {Rotation = 0}, 0.3)
						CreateTween(DropFrame, {Size = UDim2.new(1, -30, 0, 45)}, 0.3)
						if opts.Callback then opts.Callback(opt) end
					end
				end)
			end
		end

		return TabElements
	end

	return WindowArea
end

return Library
