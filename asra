		AddCorner(LeftBar, UDim.new(1, 0))

		local NTitle = Instance.new("TextLabel")
		NTitle.Size = UDim2.new(1, -28, 0, 22)
		NTitle.Position = UDim2.new(0, 18, 0, 8)
		NTitle.BackgroundTransparency = 1
